{
  "openapi": "3.0.1",
  "info": {
    "title": "CadastroLoginProtegido",
    "version": "1.0"
  },
  "paths": {
    "/api/Login": {
      "post": {
        "tags": [
          "Login"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInfoDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInfoDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInfoDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Usuarios": {
      "post": {
        "tags": [
          "Usuarios"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UsuarioCreateDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UsuarioCreateDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UsuarioCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Usuarios"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Usuarios/{id}": {
      "get": {
        "tags": [
          "Usuarios"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Cargos": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "LoginInfoDTO": {
        "required": [
          "email",
          "senha"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "senha": {
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UsuarioCreateDTO": {
        "required": [
          "cargo",
          "dataNascimento",
          "email",
          "nome"
        ],
        "type": "object",
        "properties": {
          "nome": {
            "minLength": 3,
            "type": "string"
          },
          "dataNascimento": {
            "type": "string",
            "format": "date"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "cargo": {
            "$ref": "#/components/schemas/Cargos"
          }
        },
        "additionalProperties": false
      }
    }
  }
}